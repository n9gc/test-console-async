{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsbase.json",
	"compilerOptions": {
		"outDir": "dist",
		"types": ["node"],

		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rewriteRelativeImportExtensions": true,
		"emitDeclarationOnly": false,
		"erasableSyntaxOnly": true
	},
	"include": ["**/*.ts"]
}
