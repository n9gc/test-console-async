{
  "name": "es-git",
  "version": "0.7.0",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "bugs": "https://github.com/toss/es-git/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/toss/es-git.git"
  },
  "license": "MIT",
  "packageManager": "yarn@4.14.1",
  "napi": {
    "binaryName": "es-git",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-linux-android",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "armv7-linux-androideabi"
    ]
  },
  "engines": {
    "node": ">= 10.20.0 < 11 || >= 12.17.0 < 13 || >= 14.0.0"
  },
  "workspaces": [
    "docs",
    "benchmarks"
  ],
  "scripts": {
    "build": "napi build --platform --release --no-const-enum --pipe=\"yarn transform:dts\"",
    "build:debug": "DEBUG=\"napi:*\" napi build --platform --no-const-enum --pipe=\"yarn transform:dts\"",
    "transform:dts": "jscodeshift -t transforms/dts.mjs index.d.ts",
    "check": "biome check",
    "check:fix": "biome check --write --unsafe"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@napi-rs/cli": "3.4.1",
    "@types/jscodeshift": "^0.12.0",
    "@types/node": "^22.19.18",
    "fast-glob": "^3.3.3",
    "jscodeshift": "^17.1.2",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "es-git-darwin-x64": "0.7.0",
    "es-git-darwin-arm64": "0.7.0",
    "es-git-win32-x64-msvc": "0.7.0",
    "es-git-win32-arm64-msvc": "0.7.0",
    "es-git-linux-x64-gnu": "0.7.0",
    "es-git-linux-x64-musl": "0.7.0",
    "es-git-android-arm64": "0.7.0",
    "es-git-linux-arm64-gnu": "0.7.0",
    "es-git-linux-arm64-musl": "0.7.0",
    "es-git-android-arm-eabi": "0.7.0"
  }
}